// ────────────────────────────────────────────────
//   Structure to hold segment info
// ────────────────────────────────────────────────
struct Segment {
    uintptr_t addr;
    size_t size;
    int prot;
};

// ────────────────────────────────────────────────
//   Callback for dl_iterate_phdr to find target library segments
// ────────────────────────────────────────────────
static int FindLibrarySegments(const char* target_substr, std::vector<Segment>& segments) {
    struct CallbackData {
        const char* substr;
        std::vector<Segment>* segs;
    };

    auto callback = [](struct dl_phdr_info* info, size_t size, void* data) -> int {
        auto* cbdata = static_cast<CallbackData*>(data);
        if (strstr(info->dlpi_name, cbdata->substr) == nullptr) {
            return 0;
        }

        for (int i = 0; i < info->dlpi_phnum; ++i) {
            const ElfW(Phdr)& phdr = info->dlpi_phdr[i];
            if (phdr.p_type != PT_LOAD) continue;

            int prot = 0;
            if (phdr.p_flags & PF_R) prot |= PROT_READ;
            if (phdr.p_flags & PF_W) prot |= PROT_WRITE;
            if (phdr.p_flags & PF_X) prot |= PROT_EXEC;

            cbdata->segs->push_back({
                info->dlpi_addr + phdr.p_vaddr,
                static_cast<size_t>(phdr.p_memsz),
                prot
            });
        }
        return 0;  // Continue iterating if needed
    };

    CallbackData data{target_substr, &segments};
    dl_iterate_phdr(callback, &data);
    return !segments.empty();
}

// ────────────────────────────────────────────────
//   Main remap function - stealthy and chunked
// ────────────────────────────────────────────────
bool RemapLibraryStealth(const char* target_substring, bool anti_memscan = true) {
    if (!target_substring || !*target_substring) return false;

    std::vector<Segment> segments;
    if (!FindLibrarySegments(target_substring, segments)) return false;

    // Random number generator for chunk sizes (stealth)
    std::mt19937 gen(std::chrono::steady_clock::now().time_since_epoch().count());
    std::uniform_int_distribution<size_t> dist(32 * 1024, 256 * 1024);  // 32-256 KiB

    bool overall_success = true;

    for (const auto& seg : segments) {
        if (seg.size == 0 || seg.size > 0x80000000ULL) continue;  // Sanity

        void* original = reinterpret_cast<void*>(seg.addr);
        int orig_prot = seg.prot;

        // Allocate and copy in random-sized chunks
        size_t remaining = seg.size;
        uintptr_t offset = 0;

        while (remaining > 0) {
            size_t chunk_size = std::min(dist(gen), remaining);

            void* temp = mmap(nullptr, chunk_size, PROT_READ | PROT_WRITE,
                              MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
            if (temp == MAP_FAILED) {
                overall_success = false;
                break;
            }

            // Temporarily add READ if needed
            int copy_prot = orig_prot;
            if (!(orig_prot & PROT_READ)) {
                copy_prot |= PROT_READ;
                if (mprotect(original, seg.size, copy_prot) != 0) {
                    munmap(temp, chunk_size);
                    overall_success = false;
                    break;
                }
            }

            memcpy(temp, reinterpret_cast<char*>(original) + offset, chunk_size);

            // Make destination writable for overwrite
            if (mprotect(reinterpret_cast<char*>(original) + offset, chunk_size,
                         PROT_READ | PROT_WRITE | PROT_EXEC) != 0) {
                munmap(temp, chunk_size);
                overall_success = false;
                break;
            }

            // Overwrite in place
            memcpy(reinterpret_cast<char*>(original) + offset, temp, chunk_size);

            // Restore original prot
            mprotect(reinterpret_cast<char*>(original) + offset, chunk_size, orig_prot);

            // Cleanup
            munmap(temp, chunk_size);

            offset += chunk_size;
            remaining -= chunk_size;
        }

        if (!overall_success) break;

        if (anti_memscan) {
            // Prevent core dumps / some scans
            madvise(original, seg.size, MADV_DONTDUMP);
        }
    }

    return overall_success;
}

void Init_Thread()
{
    while (!m_unity)
    {
        m_unity = Tools::GetBaseAddress("libunity.so");
        sleep(1);
    }
    LOGI("libunity.so: %p", m_unity);
    UpdateAllOffset();

    MemoryPatch::createWithHex("libunity.so", 0xa9a4a8c, "00 00 80 D2 C0 03 5F D6").Modify();
    MemoryPatch::createWithHex("libunity.so", 0xa9a4c7c, "00 00 80 D2 C0 03 5F D6").Modify();
    MemoryPatch::createWithHex("libunity.so", 0x647c5b8, "00 00 80 D2 C0 03 5F D6").Modify();

   Patches.A1 = MemoryPatch::createWithHex("libunity.so", 0x8D781DC, "1F 20 03 D5");
   Patches.rpd = MemoryPatch::createWithHex("libunity.so",0xa9ca598, "00 2C 40 BC C0 03 5F D6");
        
        //-- Bullet Track
        DobbyHook((void*)getAbsoluteAddress("libunity.so", 0xaac8a60), (void*)&WeaponFireComponent_Instant_CreateBulletLine, (void**)&oWeaponFireComponent_Instant_CreateBulletLine);
    DobbyHook((void*)getAbsoluteAddress("libunity.so", 0xaad4784), (void*)&WeaponFireComponent_Instant_CreateBulletProjectile, (void**)&oWeaponFireComponent_Instant_CreateBulletProjectile);
    
        //-- Unlock 120 fps (Codm settings)
      DobbyHook((void*)getAbsoluteAddress("libunity.so", 0xa9925f4), (void*)hooked_SetUltraFrameRateDeviceInfo, (void**)&orig_SetUltraFrameRateDeviceInfo);
        
          DobbyHook((void*)getAbsoluteAddress("libunity.so", 0xa993c10), (void*)GetFrameRateValue, (void**)&orig_GetFrameRateValue);
        
        InitializeAllHooks();
        ApplyKfox();
   
    auto swapBuffers = ((uintptr_t) DobbySymbolResolver(OBFUSCATE("libunity.so"), OBFUSCATE("eglSwapBuffers")));
    KittyMemory::ProtectAddr((void *)swapBuffers, sizeof(swapBuffers), PROT_READ | PROT_WRITE | PROT_EXEC);
    DobbyHook((void *) swapBuffers, (void *) hook_eglSwapBuffers, (void **) &old_eglSwapBuffers);


}


JNIEXPORT jint JNICALL JNI_OnLoad(JavaVM *vm, void *reserved) {
    VM = vm;

    std::thread(Init_Thread).detach();
    std::thread(Init_Thread2).detach();
    std::thread(Skins_Thread).detach();

    return JNI_VERSION_1_6;
}