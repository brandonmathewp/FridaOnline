                draw->AddText(SOCIAL, 30.f, ImVec2(pos.x + 250 - 15, pos.y + 470), ImColor(255, 255, 255, 255 / 2), "W");
                draw->AddText(SOCIAL, 30.f, ImVec2(pos.x + 250 + 15 + 50, pos.y + 470), ImColor(255, 255, 255, 255 / 2), "F");

