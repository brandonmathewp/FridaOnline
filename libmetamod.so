                    float fpsX = header3X + (header3Width - fpsSize.x) / 2.0f;
                    draw->AddText(F50, 32.0f, ImVec2(fpsX, headerY + 18), ImColor(255, 255, 255, 255), fpsText);
                    const char* fpsLabel = "FPS";
                    ImVec2 labelSize = F50->CalcTextSizeA(16.0f, FLT_MAX, 0.0f, fpsLabel);
                    float labelX = header3X + (header3Width - labelSize.x) / 2.0f;
