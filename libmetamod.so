            {
                ImVec2 delta = ImGui::GetIO().MouseDelta;
                collapsedLogoPos.x += delta.x;
                collapsedLogoPos.y += delta.y;
                wasDragging = true;
            }

            if (ImGui::IsItemDeactivated())
            {
                if (!wasDragging && windowCollapsed)
                {
                    restoreMenu = true;
                }
                wasDragging = false;
            }

            if (astralLoaded && astralTextureID)
            {
                float logoOpacity = GetLogoOpacity();
                float logoSizeMultiplier = GetLogoSizeMultiplier();
