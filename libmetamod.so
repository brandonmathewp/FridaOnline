    ImDrawList* draw = ImGui::GetWindowDrawList();

    // ===== Box dimensions =====
    float fpsBoxWidth = 90.0f;
    float fpsBoxHeight = 35.0f;
    float fpsBoxX = windowPos.x + logoWindowSize.x - fpsBoxWidth - 10.0f;
    float fpsBoxY = windowPos.y + 10.0f;

    // ===== Background box =====
    draw->AddRectFilled(
        ImVec2(fpsBoxX, fpsBoxY),
        ImVec2(fpsBoxX + fpsBoxWidth, fpsBoxY + fpsBoxHeight),
        ImColor(100, 120, 130, 200),
        17.5f
    );

    // ===== Optional border =====
    draw->AddRect(
        ImVec2(fpsBoxX, fpsBoxY),
        ImVec2(fpsBoxX + fpsBoxWidth, fpsBoxY + fpsBoxHeight),
        ImColor(255, 255, 255, 100),
        17.5f,
        ImDrawFlags_RoundCornersAll,
        2.0f
    );

    // ===== Determine FPS color =====
    ImU32 fpsColor;
    if (fps < 30.0f)
        fpsColor = IM_COL32(255, 0, 0, 255);    // red
    else if (fps < 60.0f)
        fpsColor = IM_COL32(255, 255, 0, 255);  // yellow
    else
        fpsColor = IM_COL32(0, 255, 0, 255);    // green

    // ===== FPS text =====
    if (F50) // make sure F50 is a valid ImFont*
    {
        ImVec2 textSize = F50->CalcTextSizeA(25.0f, FLT_MAX, 0.0f, fpsText);
        float textX = fpsBoxX + (fpsBoxWidth - textSize.x) / 2.0f;
        float textY = fpsBoxY + (fpsBoxHeight - textSize.y) / 2.0f;

        // Shadow for readability
        draw->AddText(F50, 25.0f, ImVec2(textX - 1, textY - 1), IM_COL32(0, 0, 0, 200), fpsText);
        draw->AddText(F50, 25.0f, ImVec2(textX + 1, textY - 1), IM_COL32(0, 0, 0, 200), fpsText);
        draw->AddText(F50, 25.0f, ImVec2(textX - 1, textY + 1), IM_COL32(0, 0, 0, 200), fpsText);
        draw->AddText(F50, 25.0f, ImVec2(textX + 1, textY + 1), IM_COL32(0, 0, 0, 200), fpsText);

        // Colored FPS text
        draw->AddText(F50, 25.0f, ImVec2(textX, textY), fpsColor, fpsText);
    }
}


            }
        }
