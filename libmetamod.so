if (TABG == 4)
                {
    // ============================================================
    //  SKINS TAB  — exact layout match of reference screenshot
    //  Strict-fit: every widget sized to ImGui::GetContentRegionAvail()
    //  so nothing overflows the parent menu, on any screen width.
    //  FIX: wrap content in a BeginChild positioned at (165,105) — same
    //  content-frame origin used by every other tab — so the tab strip
    //  (Character / Watch / Deadbox / Plane / Weapon) no longer overlaps
    //  the left sidebar and everything fits inside the menu.
    // ============================================================
    ImGui::PushStyleColor(ImGuiCol_ChildBg, ImColor(12, 12, 12, 150).Value);
    // Responsive content-frame: auto-scale to whatever size the main menu is.
    // Anchored at (165, 105) like every other tab, and fills the rest of the
    // menu minus a small right/bottom margin — so it works on any resolution.
    const float kSkinOriginX     = 165.0f;
    const float kSkinOriginY     = 105.0f;
    const float kSkinMarginR     = 10.0f;
    const float kSkinMarginB     = 10.0f;
    ImVec2      kSkinWinSize     = ImGui::GetWindowSize();
    float       kSkinChildW      = kSkinWinSize.x - kSkinOriginX - kSkinMarginR;
    float       kSkinChildH      = kSkinWinSize.y - kSkinOriginY - kSkinMarginB;
    if (kSkinChildW < 320.0f) kSkinChildW = 320.0f;   // sane floor on tiny screens
    if (kSkinChildH < 240.0f) kSkinChildH = 240.0f;
    // Fallback to the classic 675x485 layout used by other tabs if the window
    // hasn't laid out yet (size == 0 on the first frame).
    if (kSkinWinSize.x < 10.0f) { kSkinChildW = 675.0f; kSkinChildH = 485.0f; }

    ImGui::SetCursorPos(ImVec2(kSkinOriginX, kSkinOriginY));
    ImGui::BeginChild("SkinsTabContent", ImVec2(kSkinChildW, kSkinChildH), false,
                      ImGuiWindowFlags_NoScrollbar | ImGuiWindowFlags_NoScrollWithMouse);

    // ---------- Theme ----------
    const ImVec4 COL_PURPLE        = ImVec4(0.62f, 0.20f, 0.85f, 1.00f);
    const ImVec4 COL_PURPLE_DIM    = ImVec4(0.50f, 0.15f, 0.75f, 0.85f);
    const ImVec4 COL_PURPLE_TEXT   = ImVec4(0.80f, 0.45f, 1.00f, 1.00f);
    const ImVec4 COL_INPUT_BG      = ImVec4(0.06f, 0.04f, 0.10f, 0.55f);
    const ImVec4 COL_TAB_ACTIVE    = ImVec4(0.45f, 0.10f, 0.65f, 0.85f);
    const ImVec4 COL_TAB_IDLE      = ImVec4(0.00f, 0.00f, 0.00f, 0.00f);
    const ImVec4 COL_TAB_HOVER     = ImVec4(0.45f, 0.20f, 0.70f, 0.45f);
    const ImVec4 COL_TEXT_ON_DARK  = ImVec4(0.92f, 0.92f, 0.95f, 1.00f);
    const ImVec4 COL_TEXT_DIM      = ImVec4(0.78f, 0.78f, 0.85f, 0.95f);

    // Global style for this tab
    ImGui::PushStyleVar(ImGuiStyleVar_FrameRounding,   8.0f);
    ImGui::PushStyleVar(ImGuiStyleVar_ChildRounding,  10.0f);
    ImGui::PushStyleVar(ImGuiStyleVar_FrameBorderSize, 1.5f);
    ImGui::PushStyleVar(ImGuiStyleVar_ItemSpacing,    ImVec2(8, 8));
    ImGui::PushStyleColor(ImGuiCol_Border,         COL_PURPLE);
    ImGui::PushStyleColor(ImGuiCol_FrameBg,        COL_INPUT_BG);
    ImGui::PushStyleColor(ImGuiCol_FrameBgHovered, ImVec4(0.62f,0.20f,0.85f,0.30f));
    ImGui::PushStyleColor(ImGuiCol_FrameBgActive,  ImVec4(0.62f,0.20f,0.85f,0.40f));
    ImGui::PushStyleColor(ImGuiCol_CheckMark,      COL_PURPLE_TEXT);
    ImGui::PushStyleColor(ImGuiCol_Text,           COL_TEXT_ON_DARK);
    ImGui::PushStyleColor(ImGuiCol_TextDisabled,   COL_PURPLE_TEXT);

    // ============================================================
    //  PERSISTENT FAVORITES + RARITY / SEARCH STATE (file-backed)
    //  Previously stored ONLY at /sdcard/Android/data/cod_skin_favorites.cfg
    //  which on modern Android is NOT writable due to scoped-storage,
    //  so the file was silently failing to save and favorites vanished
    //  on next login. We now try a prioritized list of known-writable
    //  paths, create the parent directory if missing, and verify by
    //  reading back. First successful path becomes the active path
    //  (cached across calls) so load-on-next-launch finds the file.
    // ============================================================
    static std::unordered_map<std::string, bool> g_FavSkins;
    static bool g_FavLoaded      = false;
    static bool g_FavOnly        = false;     // "Show favorites only" toggle
    static int  g_RarityFilter   = -1;        // -1=All, 0=MYTHIC, 1=LEGENDARY, 2=EPIC, 3=COMMON
    static std::string g_FavActivePath;       // resolved writable path (cached)

    // Candidate save locations, in order of preference.
    static const char* kFavPathCandidates[] = {
        "/sdcard/Android/media/astral_skin_favorites.cfg",
        "/storage/emulated/0/Android/media/astral_skin_favorites.cfg",
        "/sdcard/astral_skin_favorites.cfg",
        "/storage/emulated/0/astral_skin_favorites.cfg",
        "/sdcard/Android/data/astral_skin_favorites.cfg",
        "/data/local/tmp/astral_skin_favorites.cfg"
    };

    auto EnsureParentDir = [](const std::string& path) {
        size_t slash = path.find_last_of('/');
        if (slash == std::string::npos || slash == 0) return;
        std::string dir = path.substr(0, slash);
        // mkdir -p (walk each segment)
        for (size_t i = 1; i <= dir.size(); ++i) {
            if (i == dir.size() || dir[i] == '/') {
                std::string sub = dir.substr(0, i);
                if (!sub.empty()) mkdir(sub.c_str(), 0775);
            }
        }
    };

    auto FavSave = [&]() {
        auto tryWrite = [&](const std::string& p) -> bool {
            EnsureParentDir(p);
            std::ofstream f(p, std::ios::trunc);
            if (!f.is_open()) return false;
            for (auto& kv : g_FavSkins) if (kv.second) f << kv.first << "\n";
            f.flush();
            f.close();
            // verify
            std::ifstream v(p);
            bool ok = v.is_open();
            v.close();
            return ok;
        };
        // If we already have an active path, keep using it.
        if (!g_FavActivePath.empty() && tryWrite(g_FavActivePath)) return;
        for (const char* cand : kFavPathCandidates) {
            if (tryWrite(cand)) { g_FavActivePath = cand; return; }
        }
    };

    auto FavLoad = [&]() {
        g_FavSkins.clear();
        auto tryRead = [&](const std::string& p) -> bool {
            std::ifstream f(p);
            if (!f.is_open()) return false;
            std::string line;
            bool any = false;
            while (std::getline(f, line)) {
                if (!line.empty()) { g_FavSkins[line] = true; any = true; }
            }
            (void)any;
            return true;
        };
        // Read from the FIRST candidate that exists; remember it as active.
        for (const char* cand : kFavPathCandidates) {
            if (tryRead(cand)) { g_FavActivePath = cand; return; }
        }
    };
    if (!g_FavLoaded) { FavLoad(); g_FavLoaded = true; }

    // Rarity helpers — strip the "[MYTHIC] " / "[LEGENDARY] " / etc. prefix
    // for CLEAN display, while keeping the original string as the stable
    // internal ID so toggles / favorites / apply logic still work.
    auto GetRarity = [](const std::string& s) -> int {
        if (s.find("[MYTHIC]")    != std::string::npos) return 0;
        if (s.find("[LEGENDARY]") != std::string::npos) return 1;
        if (s.find("[EPIC]")      != std::string::npos) return 2;
        if (s.find("[COMMON]")    != std::string::npos) return 3;
        return -1;
    };
    auto StripRarity = [](const std::string& s) -> std::string {
        size_t p = s.find(']');
        if (s.size() > 0 && s[0] == '[' && p != std::string::npos)
            return (p + 2 < s.size()) ? s.substr(p + 2) : s.substr(p + 1);
        return s;
    };
    // customCharSearch is declared below in the search row, forward-declared here
    // so PassesFilters can reference it. (Static storage => address stable.)
    static char customCharSearch[128];
    auto PassesFilters = [&](const std::string& name, bool applyCustomCharSearch = false) -> bool {
        if (!g_SkinSearch.MatchesSearch(name)) return false;
        if (g_FavOnly && !g_FavSkins[name])    return false;
        if (g_RarityFilter >= 0 && GetRarity(name) != g_RarityFilter) return false;
        // Extra filter ONLY for the Character tab: "Search Custom Char" narrows
        // the character list by name as well. Other tabs ignore this field.
        if (applyCustomCharSearch && customCharSearch[0] != '\0') {
            std::string q = ToLower(customCharSearch);
            if (ToLower(name).find(q) == std::string::npos) return false;
        }
        return true;
    };

    // ============================================================
    //  INLINE SKIN ROW RENDERER
    //  [★] Clean Name ............................ [ ON / OFF ]
    //  - Guarantees clean display (no "##id" leakage)
    //  - Compact, consistent row height
    //  - ON/OFF button right-anchored, name left-aligned
    //  - Favorite star persists to disk
    // ============================================================
    auto SkinRowInline = [&](const std::string& fullName,
                             bool* enabled,
                             const std::function<void()>& onToggle)
    {
        const float rowH    = 30.0f;
        const float starW   = 28.0f;
        const float toggleW = 62.0f;
        const float gap     = 6.0f;
        float rowW          = ImGui::GetContentRegionAvail().x;
        if (rowW < 160.0f) rowW = 160.0f;

        ImGui::PushID(fullName.c_str());          // stable unique scope
        ImVec2 rowStart = ImGui::GetCursorPos();

        // ----- Favorite star (left) -----
        bool fav = g_FavSkins[fullName];
        ImGui::PushStyleColor(ImGuiCol_Button,        ImVec4(0,0,0,0));
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, ImVec4(1.0f,0.80f,0.20f,0.25f));
        ImGui::PushStyleColor(ImGuiCol_ButtonActive,  ImVec4(1.0f,0.80f,0.20f,0.45f));
        ImGui::PushStyleColor(ImGuiCol_Text, fav ? ImVec4(1.0f,0.82f,0.22f,1.0f)
                                                 : ImVec4(0.55f,0.55f,0.60f,1.0f));
        if (ImGui::Button(fav ? "*" : "o", ImVec2(starW, rowH))) {
            g_FavSkins[fullName] = !fav;
            FavSave();
        }
        ImGui::PopStyleColor(4);

        // ----- Clean name (middle) -----
        ImGui::SameLine(0.0f, gap);
        float nameW = rowW - starW - toggleW - gap * 2.0f;
        if (nameW < 40.0f) nameW = 40.0f;

        std::string clean = StripRarity(fullName);
        int r             = GetRarity(fullName);
        ImVec4 rarityCol  = COL_TEXT_ON_DARK;
        if      (r == 0) rarityCol = ImVec4(1.00f, 0.35f, 0.35f, 1.0f); // MYTHIC red
        else if (r == 1) rarityCol = ImVec4(0.45f, 0.95f, 0.45f, 1.0f); // LEGENDARY green
        else if (r == 2) rarityCol = ImVec4(0.45f, 0.70f, 1.00f, 1.0f); // EPIC blue
        else if (r == 3) rarityCol = ImVec4(0.95f, 0.90f, 0.35f, 1.0f); // COMMON yellow

        ImVec2 textStart = ImGui::GetCursorPos();
        ImGui::BeginChild("##name", ImVec2(nameW, rowH), false,
                          ImGuiWindowFlags_NoScrollbar | ImGuiWindowFlags_NoScrollWithMouse);
        ImGui::SetCursorPosY((rowH - ImGui::GetTextLineHeight()) * 0.5f);
        if (r >= 0) {
            const char* tag = (r==0?"[MYTHIC] ":r==1?"[LEGEND] ":r==2?"[EPIC] ":"[COMMON] ");
            ImGui::TextColored(rarityCol, "%s", tag);
            ImGui::SameLine(0.0f, 2.0f);
        }
        ImGui::TextColored(COL_TEXT_ON_DARK, "%s", clean.c_str());
        ImGui::EndChild();

        // ----- Checkbox-style ON/OFF toggle (right) -----
        ImGui::SameLine(0.0f, gap);
        // A pill-track with a sliding knob. Acts as both a checkbox and a
        // visual ON/OFF indicator. Much cleaner than the old ON/OFF button.
        const float trackW = toggleW;
        const float trackH = 22.0f;
        ImVec2 cursorScreen = ImGui::GetCursorScreenPos();
        // Center vertically within rowH
        float yOff = (rowH - trackH) * 0.5f;
        ImVec2 tMin(cursorScreen.x, cursorScreen.y + yOff);
        ImVec2 tMax(tMin.x + trackW, tMin.y + trackH);

        ImGui::InvisibleButton("##toggle", ImVec2(trackW, rowH));
        bool hoveredTgl = ImGui::IsItemHovered();
        bool clickedTgl = ImGui::IsItemClicked(0);
        if (clickedTgl) {
            *enabled = !*enabled;
            onToggle();
            PushMenuNotification(fullName.c_str(), *enabled);
        }

        ImDrawList* dl = ImGui::GetWindowDrawList();
        ImU32 trackCol = *enabled
            ? ImColor(36, 180, 72, 220)           // green track (enabled)
            : ImColor(70, 18, 22, 210);           // deep red track (disabled)
        ImU32 trackBorder = *enabled
            ? ImColor(70, 220, 110, hoveredTgl ? 255 : 200)
            : ImColor(210, 70, 70,  hoveredTgl ? 255 : 170);

        dl->AddRectFilled(tMin, tMax, trackCol, trackH * 0.5f);
        dl->AddRect(tMin, tMax, trackBorder, trackH * 0.5f, 0, 1.4f);

        // Sliding knob
        float knobR = (trackH * 0.5f) - 3.0f;
        float knobX = *enabled ? (tMax.x - knobR - 3.0f) : (tMin.x + knobR + 3.0f);
        float knobY = (tMin.y + tMax.y) * 0.5f;
        dl->AddCircleFilled(ImVec2(knobX, knobY), knobR, ImColor(245, 245, 250, 255), 18);

        // Label text (ON / OFF) centered in the free half of the track
        const char* lbl = *enabled ? "ON" : "OFF";
        ImVec2 ts = ImGui::CalcTextSize(lbl);
        float lblX = *enabled ? (tMin.x + 8.0f) : (tMax.x - ts.x - 8.0f);
        float lblY = (tMin.y + tMax.y) * 0.5f - ts.y * 0.5f;
        dl->AddText(ImVec2(lblX, lblY), ImColor(255,255,255,235), lbl);

        ImGui::PopID();
        // thin separator for visual clarity between rows
        ImGui::Spacing();
    };

    // Strict available width (never exceeded by any child widget)
    float availW = ImGui::GetContentRegionAvail().x;
    if (availW < 60.0f) availW = 60.0f;

    ImGui::Spacing();

    // ===================================================
    //  TAB STRIP — Character | Watch | Deadbox | Plane | Weapon
    //  Single row, equal width, only active tab is filled
    // ===================================================
    static int  skin_tab            = 0;
    static int  prev_skin_tab       = -1;  // -1 so the very first Character-tab entry also triggers the prompt
    // Characters-tab "custom character?" gate:
    //   kCharFlowIdle  = no popup showing, no override
    //   kCharFlowAsk   = popup visible, waiting YES / NO
    //   kCharFlowTyping= user said YES, keyboard open + they pick a skin
    //   kCharFlowSkip  = user said NO, show default character list
    enum CharFlow { kCharFlowIdle = 0, kCharFlowAsk, kCharFlowTyping, kCharFlowSkip };
    static int  char_flow           = kCharFlowIdle;
    const char* tab_names[] = { "Character", "Watch", "Deadbox", "Plane", "Weapon" };
    const int   tab_count   = 5;

    float spX  = ImGui::GetStyle().ItemSpacing.x;
    float btnW = (availW - spX * (tab_count - 1)) / (float)tab_count;
    if (btnW < 40.0f) btnW = 40.0f;
    float tabH = 36.0f;

    ImGui::PushStyleVar(ImGuiStyleVar_FrameRounding, 10.0f);
    ImGui::PushStyleVar(ImGuiStyleVar_FrameBorderSize, 0.0f); // no borders on idle tabs
    for (int i = 0; i < tab_count; i++)
    {
        if (i > 0) ImGui::SameLine(0.0f, spX);
        bool selected = (skin_tab == i);

        ImGui::PushStyleColor(ImGuiCol_Button,        selected ? COL_TAB_ACTIVE : COL_TAB_IDLE);
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, selected ? COL_TAB_ACTIVE : COL_TAB_HOVER);
        ImGui::PushStyleColor(ImGuiCol_ButtonActive,  COL_TAB_ACTIVE);
        ImGui::PushStyleColor(ImGuiCol_Text,          selected ? ImVec4(1,1,1,1) : COL_TEXT_DIM);

        if (ImGui::Button(tab_names[i], ImVec2(btnW, tabH))) {
            // Re-trigger the Character prompt every time the Character tab is TAPPED
            // (even if it was already active), per user request.
            if (i == 0) char_flow = kCharFlowAsk;
            skin_tab = i;
        }

        ImGui::PopStyleColor(4);
    }
    ImGui::PopStyleVar(2);

    // Detect switching AWAY from the Character tab → close any pending flow.
    // (The prompt itself is triggered directly by the tab button click above.)
    if (skin_tab != prev_skin_tab)
    {
        if (skin_tab != 0) char_flow = kCharFlowIdle;
        prev_skin_tab = skin_tab;
    }

    ImGui::Spacing();
    ImGui::Spacing();

    // ===================================================
    //  SEARCH ROW — "Search Skin:"  +  "Search Custom Char:"
    //  Side-by-side on wide menus, stacks on narrow.
    //  NOTE: customCharSearch is declared above (static) so PassesFilters
    //  can read it. We only initialize-on-first-frame here.
    // ===================================================
    static bool  s_customCharSearchInit = false;
    if (!s_customCharSearchInit) { customCharSearch[0] = '\0'; s_customCharSearchInit = true; }
    bool  stackSearch = (availW < 480.0f);
    float searchW     = stackSearch ? availW : (availW - spX) * 0.5f;

    ImGui::PushStyleVar(ImGuiStyleVar_FramePadding, ImVec2(10, 9));

    // -- Left: Search Skin --
    ImGui::BeginGroup();
    ImGui::TextColored(COL_TEXT_DIM, "Search Skin:");
    ImGui::SetNextItemWidth(searchW);
    g_SkinSearch.RenderSearchBar();
    ImGui::EndGroup();

    if (!stackSearch) ImGui::SameLine(0.0f, spX);

    // -- Right: Search Custom Char --
    ImGui::BeginGroup();
    ImGui::TextColored(COL_TEXT_DIM, "Search Custom Char:");
    ImGui::SetNextItemWidth(searchW);
    ImGui::InputTextWithHint("##CustomCharSearch", "Type here...", customCharSearch, sizeof(customCharSearch));
    ImGui::EndGroup();

    ImGui::PopStyleVar(); // FramePadding

    ImGui::Spacing();

    // ===================================================
    //  ACTION ROW  — [ ★ Favorites ] ............ [ Keyboard ]
    //  Favorites button on LEFT toggles "show favorites only".
    //  Keyboard button on RIGHT opens the new sliding keyboard.
    // ===================================================
    static bool showKeyboardWindow = false;
    {
        const float favBtnW = 140.0f;
        const float kbBtnW  = 140.0f;

        // --- Favorites (LEFT) ---
        ImVec4 favOn  = ImVec4(1.0f, 0.82f, 0.22f, 0.90f);   // gold
        ImVec4 favOff = COL_INPUT_BG;
        ImGui::PushStyleColor(ImGuiCol_Button,        g_FavOnly ? favOn : favOff);
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, g_FavOnly ? ImVec4(1.0f,0.88f,0.30f,1.0f)
                                                                : ImVec4(0.62f,0.20f,0.85f,0.35f));
        ImGui::PushStyleColor(ImGuiCol_ButtonActive,  g_FavOnly ? ImVec4(1.0f,0.75f,0.15f,1.0f)
                                                                : COL_TAB_ACTIVE);
        ImGui::PushStyleColor(ImGuiCol_Text,          g_FavOnly ? ImVec4(0.10f,0.06f,0.00f,1.0f)
                                                                : COL_TEXT_ON_DARK);
        if (ImGui::Button(g_FavOnly ? "* Favorites (on)" : "* Favorites",
                          ImVec2(favBtnW, 26)))
            g_FavOnly = !g_FavOnly;
        ImGui::PopStyleColor(4);

        // --- Keyboard (RIGHT, pushed to far right) ---
        ImGui::SameLine(0.0f, 0.0f);
        float pushX = availW - favBtnW - kbBtnW;
        if (pushX < 6.0f) pushX = 6.0f;
        ImGui::Dummy(ImVec2(pushX, 1));
        ImGui::SameLine(0.0f, 0.0f);

        ImGui::PushStyleColor(ImGuiCol_Button,        COL_INPUT_BG);
        ImGui::PushStyleColor(ImGuiCol_ButtonHovered, ImVec4(0.62f,0.20f,0.85f,0.35f));
        ImGui::PushStyleColor(ImGuiCol_ButtonActive,  COL_TAB_ACTIVE);
        if (ImGui::Button(showKeyboardWindow ? "Hide Keyboard" : "Show Keyboard",
                          ImVec2(kbBtnW, 26)))
            showKeyboardWindow = !showKeyboardWindow;
        ImGui::PopStyleColor(3);
    }

    // New sliding virtual keyboard anchored at the bottom of the screen.
    // Typing target depends on mode:
    //   - While user is in "Custom Character TYPING" flow -> types into
    //     customCharSearch (narrows the Character list by name).
    //   - Otherwise -> types into the global Skin Search buffer.
    {
        char*  kbBuf  = (char*)g_SkinSearch.GetSearchQuery();
        size_t kbSize = 256;
        if (char_flow == kCharFlowTyping) {
            kbBuf  = customCharSearch;
            kbSize = sizeof(customCharSearch);
        }
        RenderVirtualKeyboard("##AstralVKB", kbBuf, kbSize, &showKeyboardWindow);
        // If user closes the keyboard while in typing mode, exit it.
        if (char_flow == kCharFlowTyping && !showKeyboardWindow)
            char_flow = kCharFlowIdle;
    }

    // ===================================================
    //  CHARACTER TAB — Custom-character YES/NO popup
    //  Triggered every time the user switches INTO the Character tab.
    //  YES -> opens the keyboard targeting "Search Custom Char" so the
    //         user can type the character name, then pick a skin.
    //  NO  -> falls through to the default character list.
    // ===================================================
    if (char_flow == kCharFlowAsk)
    {
        ImGui::OpenPopup("##CustomCharPrompt");
        char_flow = kCharFlowIdle; // consume the trigger; popup now owns state
    }

    {
        ImVec2 disp = ImGui::GetIO().DisplaySize;
        ImGui::SetNextWindowPos(ImVec2(disp.x * 0.5f, disp.y * 0.5f),
                                ImGuiCond_Always, ImVec2(0.5f, 0.5f));
        ImGui::SetNextWindowSize(ImVec2(460.0f, 200.0f), ImGuiCond_Always);
        ImGui::PushStyleVar(ImGuiStyleVar_WindowPadding, ImVec2(22, 20));
        ImGui::PushStyleVar(ImGuiStyleVar_WindowRounding, 14.0f);
        ImGui::PushStyleColor(ImGuiCol_PopupBg, ImVec4(0.07f, 0.04f, 0.12f, 0.97f));
        ImGui::PushStyleColor(ImGuiCol_Border,  COL_PURPLE);

        if (ImGui::BeginPopupModal("##CustomCharPrompt", nullptr,
                                   ImGuiWindowFlags_NoResize |
                                   ImGuiWindowFlags_NoMove   |
                                   ImGuiWindowFlags_NoTitleBar))
        {
            ImGui::PushFont(bold);
            ImGui::TextColored(COL_PURPLE_TEXT, "CUSTOM CHARACTER");
            ImGui::PopFont();
            ImGui::Separator();
            ImGui::Spacing();
            ImGui::TextWrapped("PLEASE TYPE THE CHARACTER THAT YOU WOULD LIKE TO CUSTOMIZE");
            ImGui::Spacing();
            ImGui::TextColored(COL_TEXT_DIM, "(The keyboard will open automatically on YES)");
            ImGui::Spacing();
            ImGui::Spacing();

            float btnW2 = 180.0f;
            float totalBtnW = btnW2 * 2 + 14.0f;
            float offX = (ImGui::GetContentRegionAvail().x - totalBtnW) * 0.5f;
            if (offX > 0) { ImGui::Dummy(ImVec2(offX, 1)); ImGui::SameLine(0,0); }

            ImGui::PushStyleColor(ImGuiCol_Button,        ImVec4(0.20f,0.75f,0.35f,0.90f));
            ImGui::PushStyleColor(ImGuiCol_ButtonHovered, ImVec4(0.28f,0.85f,0.45f,1.00f));
            ImGui::PushStyleColor(ImGuiCol_ButtonActive,  ImVec4(0.18f,0.65f,0.30f,1.00f));
            if (ImGui::Button("YES", ImVec2(btnW2, 40)))
            {
                char_flow = kCharFlowTyping;
                showKeyboardWindow = true;                     // open keyboard
                customCharSearch[0] = '\0';                    // clear prev query
                ImGui::CloseCurrentPopup();
            }
            ImGui::PopStyleColor(3);

            ImGui::SameLine(0.0f, 14.0f);

            ImGui::PushStyleColor(ImGuiCol_Button,        ImVec4(0.45f,0.10f,0.15f,0.90f));
            ImGui::PushStyleColor(ImGuiCol_ButtonHovered, ImVec4(0.60f,0.15f,0.20f,1.00f));
            ImGui::PushStyleColor(ImGuiCol_ButtonActive,  ImVec4(0.35f,0.08f,0.12f,1.00f));
            if (ImGui::Button("NO", ImVec2(btnW2, 40)))
            {
                char_flow = kCharFlowSkip;
                ImGui::CloseCurrentPopup();
            }
            ImGui::PopStyleColor(3);

            ImGui::EndPopup();
        }
        ImGui::PopStyleColor(2);
        ImGui::PopStyleVar(2);
    }

    ImGui::Spacing();

    // ===================================================
    //  CUSTOM CHARACTER — clean single-row dropdown
    //  (shown only on the Character tab, matching the reference image)
    // ===================================================
    if (skin_tab == 0)
    {
        ImGui::TextColored(COL_PURPLE_TEXT, "Custom character:");
        if (!g_targetCharacters.empty())
        {
            // Build filtered list from the "Search Custom Char" box only.
            std::vector<int>         filteredIndices;
            std::vector<const char*> filteredNames;
            std::string customLower = ToLower(customCharSearch);
            for (size_t i = 0; i < g_targetCharacters.size(); i++) {
                const auto& t = g_targetCharacters[i];
                bool match = customLower.empty() ||
                             ToLower(t.name).find(customLower) != std::string::npos;
                if (match) {
                    filteredIndices.push_back((int)i);
                    filteredNames.push_back(t.name.c_str());
                }
            }

            if (!filteredNames.empty())
            {
                int currentInFiltered = -1;
                for (size_t i = 0; i < filteredIndices.size(); i++)
                    if (filteredIndices[i] == g_selectedTargetCharIndex) { currentInFiltered = (int)i; break; }
                if (currentInFiltered == -1) currentInFiltered = 0;

                ImGui::PushStyleVar(ImGuiStyleVar_FramePadding, ImVec2(12, 10));
                ImGui::SetNextItemWidth(availW);
                if (ImGui::Combo("##TargetChar", &currentInFiltered,
                                 filteredNames.data(), (int)filteredNames.size()))
                    g_selectedTargetCharIndex = filteredIndices[currentInFiltered];
                ImGui::PopStyleVar();
            }
            else
            {
                ImGui::TextColored(ImVec4(1,0.5f,0.5f,1), "No matching characters");
            }
        }
        else ImGui::TextColored(COL_PURPLE_TEXT, "Loading target characters...");

        ImGui::Spacing();
    }

    // ===================================================
    //  SCROLLABLE LIST  (strict-fit, never overflows)
    // ===================================================
    float listH = ImGui::GetContentRegionAvail().y - 6.0f;
    if (listH < 80.0f) listH = 80.0f;

    ImGui::PushStyleColor(ImGuiCol_ChildBg, ImVec4(0.04f, 0.03f, 0.07f, 0.45f));
    ImGui::BeginChild("##SkinList", ImVec2(availW, listH), true,
                      ImGuiWindowFlags_AlwaysVerticalScrollbar);

    switch (skin_tab)
    {
    // ---------------- CHARACTERS ----------------
    case 0:
        if (!charData.empty())
        {
            for (const auto& getchar : charData)
            {
                // On the Character tab, BOTH "Search Skin" and "Search Custom Char"
                // narrow this list (AND logic). Each row toggles independently.
                if (!PassesFilters(getchar.charName, /*applyCustomCharSearch=*/true)) continue;

                SkinRowInline(getchar.charName, &sBool[getchar.charName],
                [&]() {
                    // Independent ON/OFF — no auto-disable of other character skins.
                    if (CharacterModelConfigInstance.size() > 0 &&
                        itemResourceConfigInstance.size() > 0 &&
                        RoleConfConfigInstance.size() > 0 &&
                        RolePackConfConfigInstance.size() > 0 &&
                        BRDeadboxSkinConfigInstance.size() > 0)
                    {
                        int selectedTraitor1P = g_targetCharacters[g_selectedTargetCharIndex].traitor1p;
                        if (g_targetCharacters[g_selectedTargetCharIndex].name == "Charly") selectedTraitor1P = 710001101;
                        CharacterModelFields* targetCharacter1P = nullptr;
                        for (auto charModel : CharacterModelConfigInstance) {
                            if (!charModel) continue;
                            CharacterModelFields* cf = (CharacterModelFields*)((uintptr_t)charModel + 0x10);
                            if (cf->Traitor1P == selectedTraitor1P) { targetCharacter1P = cf; break; }
                            if (cf->Traitor1P == 710001101) targetCharacter1P = cf;
                        }
                        if (targetCharacter1P) {
                            targetCharacter1P->BRBagModel         = getchar.charModel[0];
                            targetCharacter1P->BRHeadModel        = getchar.charModel[1];
                            targetCharacter1P->BRLobby            = getchar.charModel[2];
                            targetCharacter1P->BRModel            = getchar.charModel[3];
                            targetCharacter1P->BindEffect1P       = getchar.charModel[4];
                            targetCharacter1P->ChangeClipEffect1P = getchar.charModel[5];
                            targetCharacter1P->DefaultModelID     = getchar.charModel[6];
                            targetCharacter1P->Guarder1P          = getchar.charModel[7];
                            targetCharacter1P->Guarder3P          = getchar.charModel[8];
                            targetCharacter1P->GuarderBagModel    = getchar.charModel[9];
                            targetCharacter1P->GuarderHeadModel   = getchar.charModel[10];
                            targetCharacter1P->GuarderLobby       = getchar.charModel[11];
                        }

                        int selectedTraitor3P = g_targetCharacters[g_selectedTargetCharIndex].traitor3p;
                        if (g_targetCharacters[g_selectedTargetCharIndex].name == "Charly") selectedTraitor3P = 710001102;
                        CharacterModelFields* targetCharacter3P = nullptr;
                        for (auto charModel : CharacterModelConfigInstance) {
                            if (!charModel) continue;
                            CharacterModelFields* cf = (CharacterModelFields*)((uintptr_t)charModel + 0x10);
                            if (cf->Traitor3P == selectedTraitor3P) { targetCharacter3P = cf; break; }
                            if (cf->Traitor1P == 710001102) targetCharacter3P = cf;
                        }
                        if (targetCharacter3P) {
                            targetCharacter3P->BRBagModel         = getchar.charModel[0];
                            targetCharacter3P->BRHeadModel        = getchar.charModel[1];
                            targetCharacter3P->BRLobby            = getchar.charModel[2];
                            targetCharacter3P->BRModel            = getchar.charModel[3];
                            targetCharacter3P->BindEffect1P       = getchar.charModel[4];
                            targetCharacter3P->ChangeClipEffect1P = getchar.charModel[5];
                            targetCharacter3P->DefaultModelID     = getchar.charModel[6];
                            targetCharacter3P->Guarder1P          = getchar.charModel[7];
                            targetCharacter3P->Guarder3P          = getchar.charModel[8];
                            targetCharacter3P->GuarderBagModel    = getchar.charModel[9];
                            targetCharacter3P->GuarderHeadModel   = getchar.charModel[10];
                            targetCharacter3P->GuarderLobby       = getchar.charModel[11];
                        }

                        int selectedItemFieldsID = g_targetCharacters[g_selectedTargetCharIndex].itemID;
                        if (g_targetCharacters[g_selectedTargetCharIndex].name == "Charly") selectedItemFieldsID = 100301208;
                        ItemResourceFields* targetItem = nullptr;
                        for (auto itemRes : itemResourceConfigInstance) {
                            if (!itemRes) continue;
                            ItemResourceFields* itf = (ItemResourceFields*)((uintptr_t)itemRes + 0x10);
                            if (itf->ID == selectedItemFieldsID) { targetItem = itf; break; }
                            if (itf->ID == 100301208) targetItem = itf;
                        }
                        if (targetItem) {
                            targetItem->FxAssetID         = getchar.charRes[0];
                            targetItem->InventoryModelID  = getchar.charRes[1];
                            targetItem->ModelAssetIDRaw   = getchar.charRes[2];
                            targetItem->UISmallSpriteName = getchar.charRes2[0];
                            targetItem->UIMiniSpriteName  = getchar.charRes2[1];
                            targetItem->UISpriteName      = getchar.charRes2[2];
                            targetItem->UISquareSpriteName= getchar.charRes2[3];
                        }

                        int selectedRoleFID = g_targetCharacters[g_selectedTargetCharIndex].roleID;
                        if (g_targetCharacters[g_selectedTargetCharIndex].name == "Charly") selectedRoleFID = 100301208;
                        RoleConfFields* targetRole = nullptr;
                        for (auto roles : RoleConfConfigInstance) {
                            if (!roles) continue;
                            RoleConfFields* rf = (RoleConfFields*)((uintptr_t)roles + 0x10);
                            if (rf->ID == selectedRoleFID) { targetRole = rf; break; }
                            if (rf->ID == 100301208) targetRole = rf;
                        }
                        if (targetRole) {
                            targetRole->roleLeftArmID       = getchar.charRole[0];
                            targetRole->roleFinalSuitID     = getchar.charRole[1];
                            targetRole->roleBasicHologramID = getchar.charRole[2];
                            targetRole->ColorID             = getchar.charRole[3];
                            targetRole->ColorSubID          = getchar.charRole[4];
                            targetRole->ShowRare            = getchar.charRole[5];
                            targetRole->RoleLvGroupID       = getchar.charRole[6];
                            targetRole->RolePackID          = getchar.charRole[7];
                            targetRole->LOCID_Name          = getchar.charRole2[0];
                        }

                        int selectedRolePackID = g_targetCharacters[g_selectedTargetCharIndex].rolepackID;
                        for (auto pack : RolePackConfConfigInstance) {
                            if (!pack) continue;
                            packfields = (RolePackFields*)((uintptr_t)pack + 0x10);
                            if (packfields->RolePackID == selectedRolePackID) {
                                packfields->EntryAnimID      = getchar.charPack[1];
                                packfields->GestureId        = getchar.charPack[2];
                                packfields->HandEffectUI     = getchar.charPack[3];
                                packfields->LoadingFrame     = getchar.charPack[4];
                                packfields->KillStreakSkinID = getchar.charPack[5];
                            }
                        }
                    }
                });
            }
        }
        else ImGui::TextColored(ImVec4(1, 0.5f, 0.5f, 1), "No character skins loaded");
        break;

    // ---------------- WATCHES ----------------
    case 1:
        if (watch.size() > 0)
        {
            for (const auto& forwatch : watch)
            {
                if (!PassesFilters(forwatch.watchname)) continue;
                if (forwatch.watchname.find("Watch") == std::string::npos ||
                    forwatch.watchname.find("Face")  != std::string::npos) continue;

                SkinRowInline(forwatch.watchname, &sBool[forwatch.watchname],
                [&]() {
                    if (sBool[forwatch.watchname])
                        for (const auto& other : watch)
                            if (other.watchname != forwatch.watchname)
                                sBool[other.watchname] = false;

                    int selectedTraitor1P = g_targetCharacters[g_selectedTargetCharIndex].traitor1p;
                    if (g_targetCharacters[g_selectedTargetCharIndex].name == "Charly") selectedTraitor1P = 710001101;
                    if (CharacterModelConfigInstance.size() > 0)
                        for (auto charModel : CharacterModelConfigInstance) {
                            if (!charModel) continue;
                            characterfields = (CharacterModelFields*)((uintptr_t)charModel + 0x10);
                            if (characterfields->Traitor1P == selectedTraitor1P)
                                characterfields->BindEffect1P = forwatch.watchvalue;
                        }
                });
            }
        }
        else ImGui::TextColored(ImVec4(1, 0.5f, 0.5f, 1), "No watch skins loaded");
        break;

    // ---------------- DEADBOXES ----------------
    case 2:
        if (deadboxF.size() > 0)
        {
            for (const auto& deadx : deadboxF)
            {
                if (!PassesFilters(deadx.deadname)) continue;
                SkinRowInline(deadx.deadname, &sBool[deadx.deadname],
                [&]() {
                    if (sBool[deadx.deadname])
                        for (const auto& other : deadboxF)
                            if (other.deadname != deadx.deadname)
                                sBool[other.deadname] = false;
                    if (CharacterModelConfigInstance.size() > 0)
                        for (auto deadID : BRDeadboxSkinConfigInstance) {
                            if (!deadID) continue;
                            deadboxFields = (BRDeadboxSkinFields*)((uintptr_t)deadID + 0x10);
                            if (deadboxFields->ID == 180300004) {
                                deadboxFields->ColorID            = deadx.dead[0];
                                deadboxFields->DeadBoxEffectAsset = deadx.dead[1];
                                deadboxFields->Flag               = deadx.dead[2];
                                deadboxFields->FlagAsset          = deadx.dead[3];
                                deadboxFields->ModelAsset3P       = deadx.dead[4];
                                deadboxFields->ModelAssetUI       = deadx.dead[5];
                            }
                        }
                });
            }
        }
        else ImGui::TextColored(ImVec4(1, 0.5f, 0.5f, 1), "No deadbox skins loaded");
        break;

    // ---------------- PLANES ----------------
    case 3:
        if (dropplane.size() > 0)
        {
            for (const auto& planex : dropplane)
            {
                if (!PassesFilters(planex.planename)) continue;
                SkinRowInline(planex.planename, &sBool[planex.planename],
                [&]() {
                    if (sBool[planex.planename])
                        for (const auto& other : dropplane)
                            if (other.planename != planex.planename)
                                sBool[other.planename] = false;
                    if (BRDropPlaneSkinConfigInstance.size() > 0)
                        for (auto planeID : BRDropPlaneSkinConfigInstance) {
                            if (!planeID) continue;
                            dropplaneFields = (BRDropPlaneSkinFields*)((uintptr_t)planeID + 0x10);
                            if (dropplaneFields->ID == 0) {
                                dropplaneFields->ColorID            = planex.plane[0];
                                dropplaneFields->ModelAsset1P       = planex.plane[1];
                                dropplaneFields->ModelAsset3P       = planex.plane[2];
                                dropplaneFields->ModelAssetCutScene = planex.plane[3];
                                dropplaneFields->ModelAssetUI       = planex.plane[4];
                                dropplaneFields->Priority           = planex.plane[5];
                            }
                        }
                });
            }
        }
        else ImGui::TextColored(ImVec4(1, 0.5f, 0.5f, 1), "No plane skins loaded");
        break;

    // ---------------- WEAPONS ----------------
    case 4:
        if (!itemData.empty())
        {
            auto applyWeaponSkin = [&](const auto& getitem) {
                int baseID  = getitem.WeaponConf[0];
                int extraID = getitem.WeaponExtra[0];
                int skinID  = getitem.WeaponConf[2];
                int itemID  = getitem.Item2Inventory[0];
                int lootID  = getitem.Item2Inventory[3];

                for (auto item : itemInventoryInstance) {
                    if (!item) continue;
                    item2Fields = (Item2InventoryFields*)((uintptr_t)item + 0x20);
                    if (item2Fields->ItemID == getitem.Item2Inventory[0] ||
                        item2Fields->ItemID == getitem.Item2Inventory[3]) {
                        item2Fields->WeaponAssetGroupID = getitem.Item2Inventory[1];
                        item2Fields->WeaponIconID       = getitem.Item2Inventory[2];
                    }
                }
                for (auto conf : weaponConfInstance) {
                    if (!conf) continue;
                    weaponconfFields = (WeaponConfFields*)((uintptr_t)conf + 0x20);
                    if (baseID == weaponconfFields->ID || extraID == weaponconfFields->ID ||
                        skinID == weaponconfFields->ID || itemID  == weaponconfFields->ID ||
                        lootID == weaponconfFields->ID) {
                        weaponconfFields->DefWeaponSkinID    = getitem.WeaponConf[2];
                        weaponconfFields->DefaultKillBrocast = getitem.WeaponConf[3];
                        weaponconfFields->ExternalUnVisible  = true;
                        for (auto skinConf : weaponConfInstance) {
                            if (!skinConf) continue;
                            WeaponConfFields* sf = (WeaponConfFields*)((uintptr_t)skinConf + 0x20);
                            if (sf->ID == getitem.WeaponConf[2]) { weaponconfFields->LOCID_Name = sf->LOCID_Name; break; }
                        }
                        if (baseID == weaponconfFields->ID) weaponconfFields->ColorID = getitem.WeaponConf[1];
                    }
                }
                if (getitem.WeaponExtra[4] > 0) {
                    activeKillEffects[baseID]  = getitem.WeaponExtra[4];
                    activeKillEffects[extraID] = getitem.WeaponExtra[4];
                    activeKillEffects[skinID]  = getitem.WeaponExtra[4];
                    activeKillEffects[itemID]  = getitem.WeaponExtra[4];
                    activeKillEffects[lootID]  = getitem.WeaponExtra[4];
                }
                for (auto extra : weaponExtraInstance) {
                    if (!extra) continue;
                    weaponextraFields = (WeaponConfExtraFields*)((uintptr_t)extra + 0x10);
                    if (weaponextraFields->ID == baseID || weaponextraFields->ID == extraID ||
                        weaponextraFields->ID == skinID || weaponextraFields->ID == itemID  ||
                        weaponextraFields->ID == lootID) {
                        if (getitem.itemName.find("[MYTHIC]") != std::string::npos) {
                            weaponextraFields->DefaultMythicArmor = getitem.WeaponExtra[1];
                            if (getitem.itemName.find("[MYTHIC] AK117 - Memento Mori") != std::string::npos)
                                weaponextraFields->DefaultMythicSig = getitem.WeaponExtra[2];
                        }
                        weaponextraFields->DefaultDeadReplayEffectId = getitem.WeaponExtra[3];
                        weaponextraFields->DefaultKillEffectId       = getitem.WeaponExtra[4];
                    }
                }
                for (auto asset : weaponAssetGroupInstance) {
                    if (!asset) continue;
                    weaponAssetFields = (WeaponAssetGroupFields*)((uintptr_t)asset + 0x40);
                    if (weaponAssetFields->Id == getitem.WeaponAsset[0])
                        if (getitem.WeaponAsset[1] / 10 == getitem.WeaponAsset[2] / 10 && getitem.WeaponAsset[1] > 0)
                            weaponAssetFields->FireEffectGroupID = getitem.WeaponAsset[1];
                }
                for (auto itemResource : itemResourceConfigInstance) {
                    if (!itemResource) continue;
                    itemFields = (ItemResourceFields*)((uintptr_t)itemResource + 0x10);
                    if (itemFields->ID == skinID) {
                        itemFields->FxAssetID         = getitem.WeaponConf[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISpriteName      = getitem.ItemRes[2];
                        itemFields->UISquareSpriteName= getitem.ItemRes[3];
                    }
                    if (itemFields->ID == skinID) {
                        itemFields->FxAssetID         = getitem.ItemResInt[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISquareSpriteName= getitem.ItemRes[3];
                    }
                    if (itemFields->ID == itemID) {
                        itemFields->FxAssetID         = getitem.ItemResInt[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISpriteName      = getitem.ItemRes[2];
                    }
                    if (itemFields->ID == lootID) {
                        itemFields->FxAssetID         = getitem.ItemResInt[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISpriteName      = getitem.ItemRes[2];
                        itemFields->UISquareSpriteName= getitem.ItemRes[3];
                    }
                    if (itemFields->ID == extraID) {
                        itemFields->FxAssetID         = getitem.ItemResInt[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISpriteName      = getitem.ItemRes[2];
                    }
                    if (itemFields->ID == baseID) {
                        itemFields->FxAssetID         = getitem.ItemResInt[0];
                        itemFields->InventoryModelID  = getitem.ItemResInt[1];
                        itemFields->ModelAssetIDRaw   = getitem.ItemResInt[2];
                        itemFields->UIMiniSpriteName  = getitem.ItemRes[0];
                        itemFields->UISmallSpriteName = getitem.ItemRes[1];
                        itemFields->UISpriteName      = getitem.ItemRes[2];
                    }
                }

                int fireEffectID = 0;
                for (auto asset : weaponAssetGroupInstance) {
                    if (!asset) continue;
                    weaponAssetFields = (WeaponAssetGroupFields*)((uintptr_t)asset + 0x40);
                    if (weaponAssetFields && weaponAssetFields->Id == getitem.WeaponAsset[0])
                    { fireEffectID = weaponAssetFields->FireEffectGroupID; break; }
                }
                if (fireEffectID > 0) {
                    for (auto fireConf : weaponFireEffectInstance) {
                        if (!fireConf) continue;
                        WeaponFireEffectFields* wfFields = (WeaponFireEffectFields*)((uintptr_t)fireConf + 0x10);
                        if (!Tools::IsPtrValid(wfFields)) continue;
                        if (wfFields->Id == fireEffectID) {
                            wfFields->LevelEffectDelayTimeUI      = 0.1f;
                            wfFields->LevelEffectDelayTimeUI_King = 0.1f;
                            auto* a1 = *(Array<int>**)((uintptr_t)fireConf + 0x118);
                            if (a1 && Tools::IsPtrValid(a1)) for (int i = 0; i < a1->getLength(); ++i) a1->m_Items[i] = 0;
                            auto* a2 = *(Array<int>**)((uintptr_t)fireConf + 0x120);
                            if (a2 && Tools::IsPtrValid(a2)) for (int i = 0; i < a2->getLength(); ++i) a2->m_Items[i] = 0;
                            break;
                        }
                    }
                }
            };

            for (const auto& getitem : itemData) {
                if (!PassesFilters(getitem.itemName)) continue;
                if (sBool[getitem.itemName]) {
                    SkinRowInline(getitem.itemName, &sBool[getitem.itemName],
                    [&, getitem]() {
                        std::string currentBase = GetBaseWeaponName(getitem.itemName);
                        for (const auto& other : itemData)
                            if (other.itemName != getitem.itemName &&
                                GetBaseWeaponName(other.itemName) == currentBase)
                                sBool[other.itemName] = false;
                        applyWeaponSkin(getitem);
                    });
                }
            }
            for (const auto& getitem : itemData) {
                if (!PassesFilters(getitem.itemName)) continue;
                if (!sBool[getitem.itemName]) {
                    SkinRowInline(getitem.itemName, &sBool[getitem.itemName],
                    [&, getitem]() {
                        std::string currentBase = GetBaseWeaponName(getitem.itemName);
                        for (const auto& other : itemData)
                            if (other.itemName != getitem.itemName &&
                                GetBaseWeaponName(other.itemName) == currentBase)
                                sBool[other.itemName] = false;
                        applyWeaponSkin(getitem);
                    });
                }
            }
        }
        else ImGui::TextColored(ImVec4(1, 0.5f, 0.5f, 1), "No weapon skins loaded");
        break;
    }

    ImGui::EndChild();
    ImGui::PopStyleColor(); // ChildBg

    ImGui::PopStyleColor(7);
    ImGui::PopStyleVar(4);

    // Close the outer SkinsTabContent child (opened at top of TABG==4)
    ImGui::EndChild();
    ImGui::PopStyleColor(); // outer ChildBg
}



                        
                if (TABG == 5)
                {
                    ImGui::PushStyleColor(ImGuiCol_ChildBg, ImColor(12, 12, 12, 150).Value);

                    ImGui::SetCursorPos(ImVec2(165, 105));
                    ImGui::BeginChild("License_Info", ImVec2(328, 235));
                    {
                        ImVec2 startPos = ImGui::GetCursorScreenPos();
                        RenderLicenseInfo(draw, startPos);
                    }
                    ImGui::EndChild();

                    ImGui::SetCursorPos(ImVec2(165, 355));
                    ImGui::BeginChild("Logo_Adjustable", ImVec2(328, 235));
                    {
                        RenderLogoSettings(draw);
                    }
                    ImGui::EndChild();

                    ImGui::SetCursorPos(ImVec2(512, 105));
                    ImGui::BeginChild("Config_Management", ImVec2(328, 235));
                    {
                        RenderConfigManagement(draw);
                    }
                    ImGui::EndChild();

                    ImGui::SetCursorPos(ImVec2(512, 355));
                    ImGui::BeginChild("Enhancement", ImVec2(328, 235));
                    {
                        RenderEnhancement();
                    }
                    ImGui::EndChild();

                    ImGui::PopStyleColor();
                }
                
                if (Config.ExtraMenu.Rpd) {
                Patches.rpd.Modify();
            }
            else
            {
                Patches.rpd.Restore();
            }

                if (Config.ExtraMenu.WallHack)
                {
                    Patches.A1.Modify();
                }
                else
                {
                    Patches.A1.Restore();
                }
            }

            if (!Config.ExtraMenu.HideColorPicker)
            {
                ImVec2 mainMenuPos = ImGui::GetWindowPos();
                ImVec2 mainMenuSize = ImGui::GetWindowSize();

                ImGui::End();

                ImGui::SetNextWindowPos(ImVec2(mainMenuPos.x, mainMenuPos.y + mainMenuSize.y + 10), ImGuiCond_Always);
ImGui::SetNextWindowSize(ImVec2(850, 30), ImGuiCond_Always); // slightly taller for bigger slider

if (ImGui::Begin("ColorPicker", nullptr,
    ImGuiWindowFlags_NoBackground |
    ImGuiWindowFlags_NoSavedSettings |
    ImGuiWindowFlags_NoTitleBar |
    ImGuiWindowFlags_NoResize |
    ImGuiWindowFlags_NoCollapse |
    ImGuiWindowFlags_NoMove))
{
    ImDrawList* draw = ImGui::GetWindowDrawList();
    ImVec2 pos = ImGui::GetWindowPos();

    // ===== Easy-to-adjust values =====
    const float pickerWidth  = 850.0f;
    const float pickerHeight = 30.0f;   // bigger
    const float padding      = 20.0f;
    const float barHeight    = 10.0f;   // thicker
    const float barRadius    = 15.0f;
    const float selectorRadius = 15.0f; // bigger selector
    const int   segments     = 300;     // much smoother gradient

    ImColor bgColor(12, 12, 12, 150);

    // ===== Background =====
    draw->AddRectFilled(
        pos,
        ImVec2(pos.x + pickerWidth, pos.y + pickerHeight),
        bgColor,
        pickerHeight,
        ImDrawFlags_RoundCornersAll
    );

    // ===== Gradient bar =====
    float barX = pos.x + padding;
    float barY = pos.y + (pickerHeight - barHeight) * 0.5f;
    float barWidth = pickerWidth - padding * 2.0f;
    float segWidth = barWidth / segments;

    for (int i = 0; i < segments; i++)
    {
        float t1 = (float)i / segments;
        float t2 = (float)(i + 1) / segments;

        float r1, g1, b1, r2, g2, b2;
        ImGui::ColorConvertHSVtoRGB(t1, 1.0f, 1.0f, r1, g1, b1);
        ImGui::ColorConvertHSVtoRGB(t2, 1.0f, 1.0f, r2, g2, b2);

        draw->AddRectFilledMultiColor(
            ImVec2(barX + i * segWidth, barY),
            ImVec2(barX + (i + 1) * segWidth, barY + barHeight),
            ImColor(r1, g1, b1),
            ImColor(r2, g2, b2),
            ImColor(r2, g2, b2),
            ImColor(r1, g1, b1)
        );
    }

    draw->AddRect(
        ImVec2(barX, barY),
        ImVec2(barX + barWidth, barY + barHeight),
        ImColor(255, 255, 255, 100),
        barRadius,
        ImDrawFlags_RoundCornersAll,
        2.0f
    );

    // ===== Selector =====
    static float selectedPos = barWidth * 0.5f;
    float selectorX = barX + selectedPos;
    float selectorY = barY + barHeight * 0.5f;

    draw->AddCircleFilled(ImVec2(selectorX, selectorY), selectorRadius, ImColor(255, 255, 255), 64);
    draw->AddCircle(ImVec2(selectorX, selectorY), selectorRadius, ImColor(0, 0, 0), 64, 3.0f);

    // ===== Input =====
    ImGui::SetCursorPos(ImVec2(padding, (pickerHeight - barHeight) * 0.5f));
    ImGui::InvisibleButton("", ImVec2(barWidth, barHeight));

    if (ImGui::IsItemActive() || ImGui::IsItemClicked())
    {
        float mouseX = ImGui::GetMousePos().x;
        selectedPos = ImClamp(mouseX - barX, 0.0f, barWidth);

        float t = selectedPos / barWidth;
        float r, g, b;
        ImGui::ColorConvertHSVtoRGB(t, 1.0f, 1.0f, r, g, b);

        menu[0] = r;
        menu[1] = g;
        menu[2] = b;
    }
}
ImGui::End();

            }
        }
    }

    RenderMenuNotifications();

    auto Input_get_touchCount = (int (*)())(Class_Input_get_touchCount);
    if (Input_get_touchCount() > 0)
    {
        auto Input_GetTouch = (Touch(*)(uintptr_t, int))(Class_Input_GetTouch);
        auto Input_get_mousePosition = (Vector3(*)(uintptr_t))(Class_Input_get_mousePosition);
        switch (Input_GetTouch(Config.ImGuiMenu.thiz, 0).m_Phase)
        {
            case TouchPhase::Began:
            case TouchPhase::Stationary:
                io->MouseDown[0] = true;
                io->MousePos = ImVec2(Input_get_mousePosition(Config.ImGuiMenu.thiz).x, get_height() - Input_get_mousePosition(Config.ImGuiMenu.thiz).y);
                break;
            case TouchPhase::Ended:
            case TouchPhase::Canceled:
                io->MouseDown[0] = false;
                Config.ImGuiMenu.clearMousePos = true;
                break;
            case TouchPhase::Moved:
                io->MousePos = ImVec2(Input_get_mousePosition(Config.ImGuiMenu.thiz).x, get_height() - Input_get_mousePosition(Config.ImGuiMenu.thiz).y);
                break;
            default:
                break;
        }
    }

    ImGui::EndFrame();
    ImGui::Render();
    ImGui_ImplOpenGL3_RenderDrawData(ImGui::GetDrawData());
    return old_eglSwapBuffers(dpy, surface);
}
