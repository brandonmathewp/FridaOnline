struct MenuNotification
{
    std::string text;
    float createdAt;
    bool  enabled;    // true = green, false = red
};

static std::vector<MenuNotification> g_MenuNotifications;

static std::string ToUpperFeatureLabel(const char* label)
{
    std::string result;
    bool lastWasSpace = false;
    for (const char* p = label; *p; ++p)
    {
        char c = *p;
        if (c == '#' || c == '\0') break;
        if (c == '_' || c == '-') c = ' ';
        if (c >= 'a' && c <= 'z') c = (char)(c - 'a' + 'A');
        if (c == ' ')
        {
            if (!result.empty() && !lastWasSpace)
            {
                result.push_back(c);
                lastWasSpace = true;
            }
        }
        else
        {
            result.push_back(c);
            lastWasSpace = false;
        }
    }
    while (!result.empty() && result.back() == ' ') result.pop_back();
    return result.empty() ? "FEATURE" : result;
}

static void PushMenuNotification(const char* label, bool enabled)
{
    std::string message = ToUpperFeatureLabel(label);
    message += enabled ? " ENABLED" : " DISABLED";
    g_MenuNotifications.push_back({message, (float)ImGui::GetTime(), enabled});
    if (g_MenuNotifications.size() > 5)
    {
        g_MenuNotifications.erase(g_MenuNotifications.begin());
    }
}

static bool NotifyCheckbox(const char* label, bool* value)
{
    bool changed = ImGui::Checkbox(label, value);
    if (changed)
    {
        PushMenuNotification(label, *value);
    }
    return changed;
}

static void RenderMenuNotifications()
{
    const float now = (float)ImGui::GetTime();
    ImDrawList* draw = ImGui::GetForegroundDrawList();
    ImVec2 display = ImGui::GetIO().DisplaySize;
    const float lifetime = 2.8f;
    const float fadeTime = 0.35f;
    const float paddingX = 22.0f;
    const float paddingY = 14.0f;
    const float gap = 10.0f;
    float y = display.y - 34.0f;

    for (int i = (int)g_MenuNotifications.size() - 1; i >= 0; --i)
    {
        float age = now - g_MenuNotifications[i].createdAt;
        if (age > lifetime)
        {
            g_MenuNotifications.erase(g_MenuNotifications.begin() + i);
            continue;
        }

        float alpha = 1.0f;
        if (age > lifetime - fadeTime)
        {
            alpha = (lifetime - age) / fadeTime;
        }

        ImVec2 textSize = ImGui::CalcTextSize(g_MenuNotifications[i].text.c_str());
        float width = textSize.x + paddingX * 2.0f;
        float height = textSize.y + paddingY * 2.0f;
        ImVec2 min((display.x - width) * 0.5f, y - height);
        ImVec2 max(min.x + width, y);

        // Colored dot + colored text: green for ENABLED, red for DISABLED
        const bool en = g_MenuNotifications[i].enabled;
        ImU32 dotCol  = en ? ImColor(60, 220, 90, (int)(255 * alpha))
                           : ImColor(230, 60, 60, (int)(255 * alpha));
        ImU32 textCol = en ? ImColor(100, 235, 120, (int)(255 * alpha))
                           : ImColor(245, 90, 90,  (int)(255 * alpha));
        ImU32 borderCol = en ? ImColor(60, 220, 90, (int)(120 * alpha))
                             : ImColor(230, 60, 60, (int)(120 * alpha));

        draw->AddRectFilled(min, max, ImColor(12, 12, 12, (int)(220 * alpha)), 14.0f, ImDrawFlags_RoundCornersAll);
        draw->AddRect(min, max, borderCol, 14.0f, ImDrawFlags_RoundCornersAll, 1.6f);

        // leading status dot
        float dotR = 4.5f;
        ImVec2 dotCenter(min.x + paddingX + dotR, (min.y + max.y) * 0.5f);
        draw->AddCircleFilled(dotCenter, dotR, dotCol, 18);

        ImVec2 textPos(dotCenter.x + dotR + 8.0f, min.y + paddingY);
        draw->AddText(textPos, textCol, g_MenuNotifications[i].text.c_str());
        y -= height + gap;
    }
}

// ============================================================
//  NEW VIRTUAL KEYBOARD  (slide-in animated, rounded dark keys)
//  - Quick-filter keys [M] [L] [E] insert MYTHIC / LEGENDARY / EPIC
//    so they actually filter the skin list.
//  - Positioned INSIDE the current ImGui window (works anywhere we call it).
// ============================================================
struct KeyboardAnimationState {
    float hover_alpha = 0.0f;
    float press_alpha = 0.0f;
    float press_time  = 0.0f;
};

struct KeyboardState {
    bool  is_visible       = false;
    float show_time        = 0.0f;
    bool  allow_clicks     = false;
    float open_progress    = 0.0f;
    float last_frame_time  = 0.0f;
};

static std::map<std::string, KeyboardState> g_kbStates;
static std::map<std::string, KeyboardAnimationState> g_kbKeyAnims;

namespace keyboard_ui {

inline size_t SafeLen(const char* text, size_t max_len) {
    if (text == nullptr || max_len == 0) return 0;
    size_t len = 0;
    while (len < max_len && text[len] != '\0') ++len;
    return len;
}

inline void AppendText(char* buffer, size_t capacity, const char* text) {
    if (buffer == nullptr || text == nullptr || capacity == 0) return;
    size_t current_len = SafeLen(buffer, capacity);
    if (current_len >= capacity - 1) return;
    size_t add_len    = std::strlen(text);
    size_t remaining  = (capacity - 1) - current_len;
    size_t copy_len   = std::min(add_len, remaining);
    if (copy_len == 0) return;
    std::memcpy(buffer + current_len, text, copy_len);
    buffer[current_len + copy_len] = '\0';
}

inline void Backspace(char* buffer, size_t capacity) {
    if (buffer == nullptr || capacity == 0) return;
    size_t len = SafeLen(buffer, capacity);
    if (len > 0) buffer[len - 1] = '\0';
}

inline float EaseOutSmoothstep(float t) {
    t = ImClamp(t, 0.0f, 1.0f);
    return t * t * (3.0f - 2.0f * t);
}

inline float ComputeDeltaTime(float current_time, float& last_time) {
    float dt = current_time - last_time;
    if (last_time <= 0.0f || dt <= 0.0f || dt > 0.1f) dt = 1.0f / 60.0f;
    last_time = current_time;
    return dt;
}

inline bool DrawKeyButton(
    ImDrawList* draw,
    const std::string& full_id,
    const char* label,
    const ImVec2& rect_min,
    const ImVec2& rect_max,
    bool allow_clicks,
    float current_time,
    float dt,
    float ui_alpha,
    bool dark_key)
{
    auto& anim = g_kbKeyAnims[full_id];

    const bool hovered = ImGui::IsMouseHoveringRect(rect_min, rect_max);
    const bool clicked = hovered && allow_clicks && ImGui::IsMouseClicked(0);

    const float target_hover = hovered ? 1.0f : 0.0f;
    anim.hover_alpha += (target_hover - anim.hover_alpha) * (12.0f * dt);
    anim.hover_alpha = ImClamp(anim.hover_alpha, 0.0f, 1.0f);

    if (clicked) {
        anim.press_time = current_time;
        anim.press_alpha = 1.0f;
    }
    const float since_press = current_time - anim.press_time;
    if (since_press < 0.15f) anim.press_alpha = 1.0f - (since_press / 0.15f);
    else                     anim.press_alpha = 0.0f;

    const float effect_alpha = ImMax(anim.hover_alpha * 0.30f, anim.press_alpha * 0.50f);
    const float base_alpha   = dark_key ? 0.70f : 0.50f;
    const float fill_alpha   = ImClamp(base_alpha + effect_alpha, 0.0f, 1.0f) * ui_alpha;
    const ImU32 fill_col = dark_key
        ? ImColor(60, 60, 60,   (int)(255.0f * fill_alpha))
        : ImColor(100, 100, 100,(int)(255.0f * fill_alpha));

    const float rounding = 13.0f;
    draw->AddRectFilled(rect_min, rect_max, fill_col, rounding);

    const ImVec2 text_size = ImGui::CalcTextSize(label);
    const float rect_w = rect_max.x - rect_min.x;
    const float rect_h = rect_max.y - rect_min.y;
    const ImVec2 text_pos(
        rect_min.x + (rect_w - text_size.x) * 0.5f,
        rect_min.y + (rect_h - text_size.y) * 0.5f
    );
    draw->AddText(text_pos, ImColor(255, 255, 255, (int)(255.0f * ui_alpha)), label);

    return clicked;
}

} // namespace keyboard_ui

// Renders as a sliding panel ANCHORED AT THE BOTTOM of the SCREEN.
// `id` must be unique per keyboard instance; `showKeyboard` is a toggle owned
// by the caller. `searchQuery` is the char[] the keys append/backspace on.
inline void RenderVirtualKeyboard(const char* id, char* searchQuery, size_t querySize, bool* showKeyboard)
{
    if (id == nullptr || searchQuery == nullptr || querySize == 0 || showKeyboard == nullptr) return;

    const std::string keyboard_id(id);
    KeyboardState& kb_state = g_kbStates[keyboard_id];
    const float now = (float)ImGui::GetTime();

    const bool stale_hidden = (now - kb_state.last_frame_time) > 0.25f;
    if (*showKeyboard && (!kb_state.is_visible || stale_hidden)) {
        kb_state.is_visible     = true;
        kb_state.show_time      = now;
        kb_state.allow_clicks   = false;
        kb_state.open_progress  = 0.0f;
        kb_state.last_frame_time= now;
    } else if (!*showKeyboard) {
        kb_state.is_visible    = false;
        kb_state.open_progress = 0.0f;
        kb_state.allow_clicks  = false;
        return;
    }
    if (!kb_state.is_visible) return;

    const float dt = keyboard_ui::ComputeDeltaTime(now, kb_state.last_frame_time);
    kb_state.open_progress += (1.0f - kb_state.open_progress) * (8.0f * dt);
    if (kb_state.open_progress > 0.995f) kb_state.open_progress = 1.0f;
    if ((now - kb_state.show_time) > 0.10f) kb_state.allow_clicks = true;

    const float ease           = keyboard_ui::EaseOutSmoothstep(kb_state.open_progress);
    const float slide_offset_y = (1.0f - ease) * 34.0f;
    const float ui_alpha       = ease;

    ImGuiIO& io = ImGui::GetIO();
    const float screen_w = io.DisplaySize.x;
    const float screen_h = io.DisplaySize.y;
    const float keyboard_h = screen_h * 0.42f; // slightly shorter so it doesn't cover full list

    ImGui::SetNextWindowPos(ImVec2(0.0f, screen_h - keyboard_h), ImGuiCond_Always);
    ImGui::SetNextWindowSize(ImVec2(screen_w, keyboard_h), ImGuiCond_Always);

    ImGui::PushStyleVar(ImGuiStyleVar_WindowRounding,   13.0f);
    ImGui::PushStyleVar(ImGuiStyleVar_WindowBorderSize, 0.0f);
    ImGui::PushStyleVar(ImGuiStyleVar_WindowPadding,    ImVec2(24.0f, 18.0f));
    ImGui::PushStyleColor(ImGuiCol_WindowBg,
        ImVec4(18.0f/255.0f, 18.0f/255.0f, 20.0f/255.0f, (230.0f/255.0f) * ui_alpha));

    ImGui::Begin(id, nullptr,
        ImGuiWindowFlags_NoMove | ImGuiWindowFlags_NoResize |
        ImGuiWindowFlags_NoTitleBar | ImGuiWindowFlags_NoScrollbar |
        ImGuiWindowFlags_NoCollapse | ImGuiWindowFlags_NoSavedSettings);

    ImDrawList* draw = ImGui::GetWindowDrawList();
    const ImVec2 origin = ImGui::GetCursorScreenPos();
    const float content_w = ImGui::GetContentRegionAvail().x;
    const float content_h = ImGui::GetContentRegionAvail().y;

    const float key_spacing_x = 8.0f;
    const float key_spacing_y = 10.0f;
    const int   row_count     = 5;
    const float key_w         = (content_w - key_spacing_x * 9.0f) / 10.0f;
    const float max_key_h     = 60.0f;
    const float min_key_h     = 34.0f;
    const float auto_key_h    = (content_h - key_spacing_y * (row_count - 1)) / row_count;
    const float key_h         = ImClamp(auto_key_h, min_key_h, max_key_h);
    const float bottom_key_h  = key_h;

    auto row_start_x = [&](int key_count, float key_width) -> float {
        const float total_w = key_count * key_width + (key_count - 1) * key_spacing_x;
        return origin.x + (content_w - total_w) * 0.5f;
    };
    auto draw_char_row = [&](const char* row_chars, float y) -> float {
        const int count = (int)std::strlen(row_chars);
        const float start_x = row_start_x(count, key_w);
        for (int i = 0; i < count; ++i) {
            const char ch[2] = { row_chars[i], '\0' };
            const float x = start_x + i * (key_w + key_spacing_x);
            const ImVec2 rect_min(x, y + slide_offset_y);
            const ImVec2 rect_max(x + key_w, y + key_h + slide_offset_y);
            const std::string full_id = keyboard_id + "_" + ch;
            if (keyboard_ui::DrawKeyButton(draw, full_id, ch, rect_min, rect_max, kb_state.allow_clicks, now, dt, ui_alpha, false)) {
                keyboard_ui::AppendText(searchQuery, querySize, ch);
            }
        }
        return y + key_h + key_spacing_y;
    };

    float y = origin.y;
    y = draw_char_row("1234567890", y);
    y = draw_char_row("QWERTYUIOP", y);
    y = draw_char_row("ASDFGHJKL",  y);

    // Row 4: MYTHIC  Z X C V B N M  del
    {
        const float start_x = row_start_x(9, key_w);
        const char* letters = "ZXCVBNM";

        const ImVec2 m_min(start_x, y + slide_offset_y);
        const ImVec2 m_max(start_x + key_w, y + key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_MYTHIC", "MYTHIC", m_min, m_max, kb_state.allow_clicks, now, dt, ui_alpha, true))
            keyboard_ui::AppendText(searchQuery, querySize, "MYTHIC");

        for (int i = 0; i < 7; ++i) {
            char ch[2] = { letters[i], '\0' };
            const float x = start_x + (i + 1) * (key_w + key_spacing_x);
            const ImVec2 rect_min(x, y + slide_offset_y);
            const ImVec2 rect_max(x + key_w, y + key_h + slide_offset_y);
            if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_" + ch, ch, rect_min, rect_max, kb_state.allow_clicks, now, dt, ui_alpha, false))
                keyboard_ui::AppendText(searchQuery, querySize, ch);
        }

        const float del_x = start_x + 8 * (key_w + key_spacing_x);
        const ImVec2 del_min(del_x, y + slide_offset_y);
        const ImVec2 del_max(del_x + key_w, y + key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_del", "del", del_min, del_max, kb_state.allow_clicks, now, dt, ui_alpha, true))
            keyboard_ui::Backspace(searchQuery, querySize);

        y += key_h + key_spacing_y;
    }

    // Row 5: LEGENDARY   EPIC    space    Clear
    {
        const float side_w  = key_w;
        const float space_w = key_w * 5.5f + key_spacing_x * 4.5f;
        const float total_w = side_w + key_spacing_x + side_w + key_spacing_x + space_w + key_spacing_x + side_w;
        const float start_x = origin.x + (content_w - total_w) * 0.5f;

        const ImVec2 l_min(start_x, y + slide_offset_y);
        const ImVec2 l_max(start_x + side_w, y + bottom_key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_LEGEND", "LEGENDARY", l_min, l_max, kb_state.allow_clicks, now, dt, ui_alpha, true))
            keyboard_ui::AppendText(searchQuery, querySize, "LEGENDARY");

        const float e_x = start_x + side_w + key_spacing_x;
        const ImVec2 e_min(e_x, y + slide_offset_y);
        const ImVec2 e_max(e_x + side_w, y + bottom_key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_EPIC", "EPIC", e_min, e_max, kb_state.allow_clicks, now, dt, ui_alpha, true))
            keyboard_ui::AppendText(searchQuery, querySize, "EPIC");

        const float space_x = e_x + side_w + key_spacing_x;
        const ImVec2 space_min(space_x, y + slide_offset_y);
        const ImVec2 space_max(space_x + space_w, y + bottom_key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_space", "space", space_min, space_max, kb_state.allow_clicks, now, dt, ui_alpha, false))
            keyboard_ui::AppendText(searchQuery, querySize, " ");

        const float clear_x = space_x + space_w + key_spacing_x;
        const ImVec2 clear_min(clear_x, y + slide_offset_y);
        const ImVec2 clear_max(clear_x + side_w, y + bottom_key_h + slide_offset_y);
        if (keyboard_ui::DrawKeyButton(draw, keyboard_id + "_clear", "Clear", clear_min, clear_max, kb_state.allow_clicks, now, dt, ui_alpha, true))
            searchQuery[0] = '\0';
    }

    ImGui::End();
    ImGui::PopStyleColor();
    ImGui::PopStyleVar(3);
}


static void CheckTopCenterMenuRestore()
{
    if (isMenuVisible)
    {
        return;
    }

    ImGuiIO& io = ImGui::GetIO();
    if (io.MouseClicked[0])
    {
        float screenWidth = get_width();
        float areaWidth = 200.0f;
        float areaHeight = 50.0f;
        float minX = (screenWidth * 0.5f) - (areaWidth * 0.5f);
        float maxX = (screenWidth * 0.5f) + (areaWidth * 0.5f);

        if (io.MousePos.x >= minX && io.MousePos.x <= maxX && io.MousePos.y >= 0.0f && io.MousePos.y <= areaHeight)
        {
            isMenuVisible = true;
            windowCollapsed = false;
        }
    }
}

#define CREATE_COLOR(r, g, b, a) new float[4]{r / 255.0f, g / 255.0f, b / 255.0f, a / 255.0f};

int TABG = 1;

struct TextureInfo
{
    ImTextureID textureId;
    int x;
    int y;
    int w;
    int h;
};

TextureInfo mPlayersOn;
TextureInfo mPlayersOff;
TextureInfo mWorldOn;
TextureInfo mWorldOff;
TextureInfo mRageBotOn;
TextureInfo mRageBotOff;
TextureInfo mScriptsOn;
TextureInfo mScriptsOff;
TextureInfo mSettingsOn;
TextureInfo mSettingsOff;
TextureInfo DOT;
TextureInfo Logo;

TextureInfo CreateTexture(const unsigned char *buf, int len)
{
    TextureInfo image;
    unsigned char *image_data = stbi_load_from_memory(buf, len, &image.w, &image.h, NULL, 0);
    if (image_data == NULL)
    {
        perror("File does not exist");
    }
    GLuint image_texture;
    glGenTextures(1, &image_texture);
    glBindTexture(GL_TEXTURE_2D, image_texture);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);

    #if defined(GL_UNPACK_ROW_LENGTH) && !defined(__EMSCRIPTEN__)
    glPixelStorei(GL_UNPACK_ROW_LENGTH, 0);
    #endif

    glTexImage2D(GL_TEXTURE_2D, 0, GL_RGBA, image.w, image.h, 0, GL_RGBA, GL_UNSIGNED_BYTE, image_data);
    stbi_image_free(image_data);
    image.textureId = (ImTextureID)image_texture;
    return image;
}

void InitTexture()
{
    Logo = CreateTexture(Logo_data, sizeof(Logo_data));
    mPlayersOn = CreateTexture(PlayersOn, sizeof(PlayersOn));
    mPlayersOff = CreateTexture(PlayersOff, sizeof(PlayersOff));
    mWorldOn = CreateTexture(WorldOn, sizeof(WorldOn));
    mWorldOff = CreateTexture(WorldOff, sizeof(WorldOff));
    mRageBotOn = CreateTexture(RageBotOn, sizeof(RageBotOn));
    mRageBotOff = CreateTexture(RageBotOff, sizeof(RageBotOff));
    mScriptsOn = CreateTexture(ScriptsOn, sizeof(ScriptsOn));
    mScriptsOff = CreateTexture(ScriptsOff, sizeof(ScriptsOff));
    mSettingsOn = CreateTexture(SettingsOn, sizeof(SettingsOn));
    mSettingsOff = CreateTexture(SettingsOff, sizeof(SettingsOff));
    DOT = CreateTexture(DOT_data, sizeof(DOT_data));
}


// ================================================================================================
// OPTIONAL: TOP-LEFT FPS (same style as your previous "like that" black look)
// ================================================================================================
static void RenderTopLeftFPS(ImDrawList* draw)
{
    if (!draw) return;

    ImFont* font = ImGui::GetFont();
    float fps = ImGui::GetIO().Framerate;

    const float x = 50.0f;
    const float y = 60.0f;
    const float fs = 30.0f;

    ImU32 fpsCol =
        (fps >= 60.0f) ? IM_COL32(110, 255, 170, 255) :
        (fps >= 30.0f) ? IM_COL32(255, 215,  80, 255) :
        (fps >=  1.0f) ? IM_COL32(255,  90,  90, 255) :
                         IM_COL32(160, 160, 160, 200);

    char txt[32];
    std::snprintf(txt, sizeof(txt), "FPS : %d", (int)(fps + 0.5f));

    draw->AddText(font, fs, ImVec2(x + 1.5f, y + 1.5f), IM_COL32(0, 0, 0, 170), txt);
    draw->AddText(font, fs, ImVec2(x, y), fpsCol, txt);
}

// ================================================================================================
// YOUR RenderFloatingInfo (DARK BLACK PRO THEME)
// ================================================================================================
void RenderFloatingInfo(ImDrawList* draw, float screenWidth, float screenHeight)
{
    if (!draw) return;
    if (Config.ExtraMenu.ClearDisplay) return;

    // Optional FPS like your previous black version
    RenderTopLeftFPS(draw);

    // ===== TIME / DATE =====
    auto now = std::chrono::system_clock::now();
    std::time_t currentTime = std::chrono::system_clock::to_time_t(now);
    std::tm* localTime = std::localtime(&currentTime);

    char dateStr[48], timeStr[32];
    strftime(dateStr, sizeof(dateStr), "%d %b %Y", localTime);
    strftime(timeStr, sizeof(timeStr), "%I:%M:%S %p", localTime);

    // ===== UPTIME =====
    auto currentDuration = std::chrono::steady_clock::now() - appStartTime;
    std::string playTime = FormatTimeDuration(currentDuration);

    // ===== CONTENT =====
    const char* subText   = "SUBSCRIPTION : PREMIUM";
    const char* titleText = "CODM GARENA | 1.6.55";
    const char* tgText    = "TELEGRAM : @Feylric";
    const char* warnText  = "PLAY SAFE TO AVOID BAN";

    char lineDate[80], lineTime[80], lineUp[96];
    std::snprintf(lineDate, sizeof(lineDate), "DATE : %s", dateStr);
    std::snprintf(lineTime, sizeof(lineTime), "TIME : %s", timeStr);
    std::snprintf(lineUp,   sizeof(lineUp),   "UPTIME : %s", playTime.c_str());

    // ===== THEME (DARK BLACK PRO) =====
    // Clean black glass + subtle border + minimal accent
    const ImU32 colShadow   = IM_COL32(0, 0, 0, 150);
    const ImU32 colPanel    = IM_COL32(10, 10, 12, 235);      // near-black
    const ImU32 colBorder   = IM_COL32(255, 255, 255, 30);    // subtle white
    const ImU32 colDivider  = IM_COL32(255, 255, 255, 18);
    const ImU32 colAccent   = IM_COL32(255, 255, 255, 40);    // minimal bar
    const ImU32 colMuted    = IM_COL32(190, 195, 205, 200);
    const ImU32 colGreen    = IM_COL32(110, 255, 170, 255);   // keep premium green
    const ImU32 colDot      = IM_COL32(110, 255, 170, 230);

    // Warning pulse
    float tNow = (float)ImGui::GetTime();
    float pulse = 0.5f + 0.5f * sinf(tNow * 3.0f);
    ImU32 colWarn = IM_COL32(255, (int)(95 + pulse * 75), (int)(95 + pulse * 75), 255);

    // ===== FONT / SIZES =====
    ImFont* font = ImGui::GetFont();
    const float fsTitle = 18.5f;
    const float fsSub   = 16.0f;
    const float fsInfo  = 15.2f;
    const float fsWarn  = 16.0f;

    // ===== WIDTH AUTO FIT =====
    auto TextW = [&](const char* s, float sz) -> float {
        return font->CalcTextSizeA(sz, FLT_MAX, 0.0f, s).x;
    };

    float maxW = 0.0f;
    maxW = ImMax(maxW, TextW(titleText, fsTitle));
    maxW = ImMax(maxW, TextW(subText,   fsSub));
    maxW = ImMax(maxW, TextW(lineDate,  fsInfo));
    maxW = ImMax(maxW, TextW(lineTime,  fsInfo));
    maxW = ImMax(maxW, TextW(lineUp,    fsInfo));
    maxW = ImMax(maxW, TextW(tgText,    fsInfo));
    maxW = ImMax(maxW, TextW(warnText,  fsWarn));

    float paddingX = 18.0f;
    float paddingY = 16.0f;
    float lineH    = 22.0f;
    float boxW     = maxW + paddingX * 2.0f + 6.0f;
    float boxH     = paddingY * 2.0f + lineH * 6.0f + 12.0f;

    float margin   = 22.0f;
    float x0       = margin;
    float y0       = screenHeight - margin - boxH;
    float rounding = 14.0f;

    // ===== PANEL =====
    draw->AddRectFilled(ImVec2(x0 + 3.0f, y0 + 4.0f),
                        ImVec2(x0 + boxW + 3.0f, y0 + boxH + 4.0f),
                        colShadow, rounding);

    draw->AddRectFilled(ImVec2(x0, y0),
                        ImVec2(x0 + boxW, y0 + boxH),
                        colPanel, rounding);

    draw->AddRect(ImVec2(x0, y0),
                  ImVec2(x0 + boxW, y0 + boxH),
                  colBorder, rounding, 0, 1.5f);

    // Accent bar
    draw->AddRectFilled(ImVec2(x0, y0),
                        ImVec2(x0 + 4.0f, y0 + boxH),
                        colAccent, rounding, ImDrawFlags_RoundCornersLeft);

    // Divider
    draw->AddLine(ImVec2(x0 + 12.0f, y0 + paddingY + lineH + 4.0f),
                  ImVec2(x0 + boxW - 12.0f, y0 + paddingY + lineH + 4.0f),
                  colDivider, 1.0f);

    // Status dot
    draw->AddCircleFilled(ImVec2(x0 + boxW - 18.0f, y0 + 18.0f), 4.0f, colDot);

    // ===== TEXT =====
    float x = x0 + paddingX;
    float y = y0 + paddingY;

    // ===== RAINBOW TITLE (TONED DOWN FOR BLACK THEME) =====
    {
        float t = (float)ImGui::GetTime() * 0.6f;

        float r = sinf(t) * 0.5f + 0.5f;
        float g = sinf(t + 2.094f) * 0.5f + 0.5f;
        float b = sinf(t + 4.188f) * 0.5f + 0.5f;

        // keep it premium (closer to white)
        ImU32 rainbowCol = ImColor(
            r * 0.25f + 0.75f,
            g * 0.25f + 0.75f,
            b * 0.25f + 0.75f,
            1.0f
        );

        draw->AddText(font, fsTitle, ImVec2(x + 1.2f, y + 1.2f), IM_COL32(0, 0, 0, 170), titleText);
        draw->AddText(font, fsTitle, ImVec2(x, y), rainbowCol, titleText);
    }

    y += lineH + 8.0f;

    draw->AddText(font, fsSub,  ImVec2(x, y), colGreen, subText);  y += lineH;
    draw->AddText(font, fsInfo, ImVec2(x, y), colMuted, lineDate); y += lineH;
    draw->AddText(font, fsInfo, ImVec2(x, y), colMuted, lineTime); y += lineH;
    draw->AddText(font, fsInfo, ImVec2(x, y), colMuted, lineUp);   y += lineH;
    draw->AddText(font, fsInfo, ImVec2(x, y), colMuted, tgText);   y += lineH;
    draw->AddText(font, fsWarn, ImVec2(x, y), colWarn,  warnText);
}


EGLBoolean (*old_eglSwapBuffers)(EGLDisplay dpy, EGLSurface surface);
