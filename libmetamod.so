                draw->AddRectFilled(ImVec2(pos.x + 0, pos.y + 0), ImVec2(pos.x + 500, pos.y + 530), ImColor(0, 0, 0, 255), 5.f, ImDrawFlags_RoundCornersAll);
                draw->AddRectFilled(ImVec2(pos.x + 10, pos.y + 10), ImVec2(pos.x + 490, pos.y + 520), ImColor(50, 50, 50, 255), 8.f, ImDrawFlags_RoundCornersAll);
                draw->AddRectFilled(ImVec2(pos.x + 30, pos.y + 150), ImVec2(pos.x + 470, pos.y + 210), ImColor(0, 0, 0, 255), 10.f, ImDrawFlags_RoundCornersAll);
