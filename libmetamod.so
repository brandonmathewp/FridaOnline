                    float textY = headerY + (headerHeight / 2.0f) - 10.0f;
                    draw->AddText(F50, 22.0f, ImVec2(textX, textY), ImColor(255, 255, 255, 255), versionText);
                }

                draw->AddRectFilled(ImVec2(header2X, headerY), ImVec2(header2X + header2Width, headerY + headerHeight), headerBgColor, headerRadius, ImDrawFlags_RoundCornersAll);
                float iconSize = 75.0f;
                float iconPadding = (headerHeight - iconSize) / 2.0f;
                ImTextureID currentIcon = mPlayersOff.textureId;
                const char* currentTabName = "Visual";
                const char* currentTabDesc = "See Enemy Through Walls";
                if (TABG == 1)
                {
                    currentIcon = mPlayersOff.textureId;
                    currentTabName = "Visuals";
                    currentTabDesc = "See Enemy Through Walls";
                }
                else if (TABG == 2)
                {
                    currentIcon = mRageBotOff.textureId;
                    currentTabName = "Combat";
                    currentTabDesc = "Destroy everyone in your path";
                }
                else if (TABG == 3)
                {
                    currentIcon = mWorldOff.textureId;
                    currentTabName = "Memory";
                    currentTabDesc = "Control over the whole map";
                }
                else if (TABG == 4)
                {
                    currentIcon = mScriptsOff.textureId;
                    currentTabName = "Skins";
                    currentTabDesc = "Customize your weapons";
                }
                else if (TABG == 5)
                {
                    currentIcon = mSettingsOff.textureId;
                    currentTabName = "Settings";
                    currentTabDesc = "Change Theme and Menu Design";
                }
                draw->AddImageRounded(currentIcon, ImVec2(header2X + 10, headerY + iconPadding), ImVec2(header2X + 10 + iconSize, headerY + iconPadding + iconSize), ImVec2(0, 0), ImVec2(1, 1), ImColor(255, 255, 255, 255), 8.0f, ImDrawFlags_RoundCornersAll);
                if (F50)
