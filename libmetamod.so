            ImGui::SetNextWindowSize(ImVec2(850, 600), ImGuiCond_Always);

            if (ImGui::Begin("SovereignAstral", nullptr, ImGuiWindowFlags_NoBackground | ImGuiWindowFlags_NoSavedSettings | ImGuiWindowFlags_AlwaysAutoResize | ImGuiWindowFlags_NoTitleBar | ImGuiWindowFlags_NoResize | ImGuiWindowFlags_NoCollapse | ImGuiWindowFlags_NoMove))
            {
                const ImVec2 pos = ImGui::GetWindowPos();
                ImDrawList *draw = ImGui::GetWindowDrawList();

                draw->AddRectFilled(ImVec2(0 + pos.x, 0 + pos.y), ImVec2(850 + pos.x, 600 + pos.y), ImColor(12, 12, 12, 80), 25.0f, ImDrawFlags_RoundCornersAll);

                float headerY = pos.y + 10;
                float headerHeight = 85;
                float headerStartX = pos.x + 10;

                float header1X = headerStartX;
                float header1Width = 250.0f;

                float header2X = header1X + header1Width + 10.0f;
                float header2Width = 315.0f;

                float header3X = header2X + header2Width + 10.0f;
                float header3Width = 90.0f;

                float header4X = header3X + header3Width + 10.0f;
                float header4Width = 147.0f;

                ImColor headerBgColor = ImColor(12, 12, 12, 150);
                float headerRadius = 20.0f;

                draw->AddRectFilled(ImVec2(header1X, headerY), ImVec2(header1X + header1Width, headerY + headerHeight), headerBgColor, headerRadius, ImDrawFlags_RoundCornersAll);
                float logoSize = 60.0f;
                float logoPadding = (headerHeight - logoSize) / 2.0f;
                draw->AddImageRounded(DOT.textureId, ImVec2(header1X + logoPadding, headerY + logoPadding), ImVec2(header1X + logoPadding + logoSize, headerY + logoPadding + logoSize), ImVec2(0, 0), ImVec2(1, 1), ImColor(255, 255, 255, 255), 8.0f, ImDrawFlags_RoundCornersAll);
                if (F50)
                {
